---
import ProjectPageLayout from '../../layouts/ProjectPageLayout.astro';
import Image from '../../components/Image.astro'
---
<ProjectPageLayout title="Unreal VR Circus">
    <h1>VR Circus Experience in Unreal Engine</h1>
    <p>
        Project description placeholder - overview of the VR circus experience
        and goals.
    </p>
    <br>
    <p>
        Introduction paragraph about VR development and circus theme concept.
    </p>
    <p>
        Development challenges and approach paragraph.
    </p>
    <Image
            src="/images/UnrealVRCircus/placeholder-image.webp"
            alt="VR Circus scene screenshot"
            description="Main circus environment showcase"
            loading="eager"
    />
    <p>
        Technical implementation details paragraph.
    </p>
    <Image
            src="/images/UnrealVRCircus/placeholder-image-2.webp"
            alt="VR interaction demonstration"
            description="Player interaction showcase"
            loading="eager"
    />
    <p>
        Results and performance considerations paragraph.
    </p>
    <Image
            src="/images/UnrealVRCircus/placeholder-image-3.webp"
            alt="VR circus performance elements"
            description="Circus acts and performances"
            loading="eager"
    />
    <h3>Development Process</h3>
    <p>
        Development methodology and tools used.
    </p>
    <Image
            src="/images/UnrealVRCircus/development-screenshot.png"
            alt="Unreal Engine VR development setup"
            description="Blueprint and level design setup"
    />
    <p>
        Blueprint logic explanation paragraph.
    </p>
    <Image
            src="/images/UnrealVRCircus/blueprint-graph.png"
            alt="VR interaction blueprint graph"
            description="Core VR interaction system blueprint"
    />
    <p>
        Technical details about VR implementation.
    </p>
    <h3>Features & Interactions</h3>
    <p>
        VR interaction systems and features overview.
    </p>
    <Image
            alt="VR hand tracking interface"
            description="Hand tracking and gesture recognition"
            src="/images/UnrealVRCircus/hand-tracking.png"
    />
    <p>
        User experience and immersion elements.
    </p>
    <Image
            alt="Circus performance showcase"
            description="Interactive circus performances"
            src="/images/UnrealVRCircus/circus-acts.png"
    />
    <p>
        Final implementation and user feedback.
    </p>
    <Image
            alt="Complete VR circus experience"
            description="Full immersive circus environment"
            src="/images/UnrealVRCircus/complete-experience.webp"
            loading="eager"
    />
    <p>
        Testing and optimization results.
    </p>
    <Image
            alt="VR performance metrics"
            description="Performance optimization showcase"
            src="/images/UnrealVRCircus/performance-metrics.webp"
            loading="eager"
    />
    <!-- Optional embedded content section -->
    <div style="display: flex; justify-content: center; width: 100%;">
        <!-- Placeholder for potential embedded demo or video -->
    </div>

</ProjectPageLayout>